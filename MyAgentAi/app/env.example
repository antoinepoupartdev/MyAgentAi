# Example environment file (DO NOT put real keys in the repo).
# Copy to: app/.env
#
# Required: ElevenLabs (STT + TTS)
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_STT_MODEL_ID=scribe_v2
ELEVENLABS_TTS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID
ELEVENLABS_TTS_OUTPUT_FORMAT=pcm_24000
#
# Required: Gemini (LLM)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
#
# Optional: Gemini model override
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
#
# Optional: Microphone selection (sounddevice input device index)
# STT_INPUT_DEVICE=12
#
# Optional: Recording / VAD tuning (reduce latency vs accuracy)
# STT_MAX_RECORD_SECONDS=4.0
# STT_CHUNK_DURATION_SECONDS=0.25
# STT_VOICE_THRESHOLD=500
# STT_INITIAL_SILENCE_TIMEOUT_SECONDS=2.0
# STT_END_SILENCE_SECONDS=0.75
# STT_MIN_SPEECH_SECONDS=0.4
